# Copy this to .env and fill in your values
# The mobile app reads EXPO_PUBLIC_VERIFY_URL to know where to send verification requests

# Your deployed Netlify URL (set after first deploy)
EXPO_PUBLIC_VERIFY_URL=https://your-site.netlify.app/.netlify/functions/verify

# For local development with netlify dev:
# EXPO_PUBLIC_VERIFY_URL=http://localhost:8888/.netlify/functions/verify
